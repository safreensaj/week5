<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h1>Registered Students</h1>
    <table border="1">
        <tr>
            <th>Name</th>
            <th>Age</th>
            <th>Class</th>
        </tr>
        <%students.forEach(student=>{%>
            <tr>
                <td>
                    <%=student.name%>
                </td>
                <td>
                    <%=student.age%>
                </td>
                <td>
                    <%=student.class%>
                </td>
            </tr>
            <% }) %>
    </table>

</body>

</html>